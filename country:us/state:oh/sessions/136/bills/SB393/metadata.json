  "abstracts": [
    {
      "note": "long title",
      "abstract": "To amend sections 959.21, 959.99, 2907.04, 2907.05, 2907.321, 2907.322, 2907.323, 2929.14, and 2950.01 and to enact section 2941.1427 of the Revised Code to make changes to various sexually oriented offenses involving juvenile victims and to create the offenses of creating or possessing material depicting sexual conduct with an animal."
    }
  ],
