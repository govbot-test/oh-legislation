  "abstracts": [
    {
      "note": "long title",
      "abstract": "To amend sections 117.30, 117.36, and 1715.51 and to enact sections 117.281, 1715.60, 1715.61, 1715.62, 1715.63, 1715.64, 1715.65, 1715.66, 1715.67, 1715.68, 1715.69, 1715.70, and 1715.71 of the Revised Code to establish standards for transparency and oversight of non-private endowment funds and to permit the state to recover public money provided to tax-exempt organizations that fail to comply with federal tax regulation and reporting law."
    }
  ],
  "other_titles": [
