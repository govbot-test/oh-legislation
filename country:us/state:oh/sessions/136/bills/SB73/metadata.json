  "abstracts": [
    {
      "note": "long title",
      "abstract": "To amend sections 3314.03, 3326.11, 3328.24, and 4112.01 and to enact section 3313.6612 of the Revised Code to enact the Creating a Respectful and Open World for Natural Hair (CROWN) Act to prohibit discrimination against an individual based on hair texture and protective hair styles."
    }
  ],
