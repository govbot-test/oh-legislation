  "abstracts": [
    {
      "note": "long title",
      "abstract": "To amend sections 1.61, 303.01, 519.01, 901.511, 929.01, 1311.55, 1729.01, and 5501.50 of the Revised Code to expressly include the production of maple syrup and maple products in the laws relating to agriculture."
    }
  ],
  "other_titles": [
    {
      "note": "long title",
      "title": "To amend sections 1.61, 303.01, 519.01, 901.511, 929.01, 1311.55, 1729.01, and 5501.50 of the Revised Code to expressly include the production of maple syrup and maple products in the laws relating to agriculture."
    },
    {
      "note": "long title",
      "title": "To amend sections 1.61, 303.01, 519.01, 901.511, 929.01, 1311.55, 1729.01, 5501.50, and 5713.30 of the Revised Code to expressly include the cultivation of trees to produce maple syrup and maple products in the laws relating to agriculture."
    },
    {
      "note": "long title",
      "title": "To amend sections 1.61, 303.01, 519.01, 901.511, 929.01, 1311.55, 1729.01, 5501.50, and 5713.30 of the Revised Code to expressly include the cultivation of trees to produce maple syrup and maple products in the laws relating to agriculture."
    }
  ],
