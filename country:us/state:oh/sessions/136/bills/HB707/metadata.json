  "abstracts": [
    {
      "note": "long title",
      "abstract": "To amend sections 2151.421, 3314.03, 3326.11, 3328.24, 5180.40, 5180.401, 5180.402, 5180.403, and 5180.404 and to enact sections 3313.961, 5180.408, 5180.409, 5180.4010, and 5180.4011 of the Revised Code to make changes to the law regarding the uniform statewide automated child welfare information system, to require public schools to appoint a child protection liaison, and to name this act Kei'Mani's Law."
    }
  ],
