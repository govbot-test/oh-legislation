{
  "legislative_session": "136",
  "identifier": "HB 20",
  "title": "Prohibit harassing or impeding an emergency service responder",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Crime and Punishment",
    "Crimes, Corrections, and Law Enforcement",
    "Law Enforcement"
  ],
  "abstracts": [
    {
      "note": "long title",
      "abstract": "To amend section 2903.22 and to enact section 2927.31 of the Revised Code to prohibit a person from knowingly harassing or impeding an emergency service responder who is engaged in the lawful performance of a legal duty and to clarify that heightened penalties apply for menacing a probation officer."
    }
  ],
  "other_titles": [
    {
      "note": "long title",
      "title": "To amend section 2903.22 and to enact section 2927.31 of the Revised Code to prohibit a person from knowingly harassing or impeding an emergency service responder who is engaged in the lawful performance of a legal duty and to clarify that heightened penalties apply for menacing a probation officer."
    },
    {
      "note": "long title",
      "title": "To amend sections 2903.22 and 2921.31 of the Revised Code to increase the penalty for obstructing official business when the victim is an emergency service responder who is engaged in the lawful performance of a legal duty and to clarify that heightened penalties apply for menacing a probation officer."
    },
    {
      "note": "long title",
      "title": "To amend sections 2903.22 and 2921.31 of the Revised Code to increase the penalty for obstructing official business when the victim is an emergency service responder who is engaged in the lawful performance of a legal duty and to clarify that heightened penalties apply for menacing a probation officer."
    },
    {
      "note": "long title",
      "title": "To amend sections 2903.22 and 2921.31 of the Revised Code to modify the offense of obstructing official business when the victim is an emergency service responder, to increase the penalty for obstructing official business when the victim is an emergency service responder who is engaged in the lawful performance of a legal duty, and to clarify that heightened penalties apply for menacing a probation officer."
    },
    {
      "note": "long title",
      "title": "To amend sections 2903.22 and 2921.31 of the Revised Code to modify the offense of obstructing official business when the victim is an emergency service responder, to increase the penalty for obstructing official business when the victim is an emergency service responder who is engaged in the lawful performance of a legal duty, and to clarify that heightened penalties apply for menacing a probation officer."
    },
    {
      "note": "long title",
      "title": "To amend sections 2903.22 and 2921.31 of the Revised Code to modify the offense of obstructing official business when the victim is an emergency service responder, to increase the penalty for obstructing official business when the victim is an emergency service responder who is engaged in the lawful performance of a legal duty, and to clarify that heightened penalties apply for menacing a probation officer."
    }
  ],
