  "abstracts": [
    {
      "note": "long title",
      "abstract": "To enact sections 5164.40, 5164.401, 5164.402, 5164.403, 5164.404, 5164.405, and 5164.406 of the Revised Code to require the Department of Medicaid to establish electronic verification systems that promote program integrity for certain components of the Medicaid program and to name this act the Safeguarding Healthcare Integrity through Electronic Location Data (SHIELD) Act."
    }
  ],
  "other_titles": [
