{
  "legislative_session": "136",
  "identifier": "HB 649",
  "title": "Enact the Child Care Fraud Prevention Act",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Child Care",
    "Health and Human Services"
  ],
  "abstracts": [
    {
      "note": "long title",
      "abstract": "To amend sections 5104.015 and 5104.04 and to enact sections 5104.044, 5104.303, 5104.304, and 5104.361 of the Revised Code to require video surveillance of child care centers, to establish an online portal for tracking child care center attendance, to require investigations of waste, fraud, and abuse allegations relating to providers of publicly funded child care, and to name this act the Child Care Fraud Prevention Act."
    }
  ],
  "other_titles": [
    {
      "note": "long title",
      "title": "To amend sections 5104.015 and 5104.04 and to enact sections 5104.044, 5104.303, 5104.304, and 5104.361 of the Revised Code to require video surveillance of child care centers, to establish an online portal for tracking child care center attendance, to require investigations of waste, fraud, and abuse allegations relating to providers of publicly funded child care, and to name this act the Child Care Fraud Prevention Act."
    }
  ],
