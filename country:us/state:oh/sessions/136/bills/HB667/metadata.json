  "abstracts": [
    {
      "note": "long title",
      "abstract": "To amend sections 2929.141, 2929.34, 2935.10, 2935.11, 5120.021, 5120.038, 5589.21, and 5589.211 of the Revised Code to enact the Reagan Tokes and Patrick Heringer Act to require certain warrants to be entered into LEADS, to require GPS monitoring of offenders released from prison, and to modify T-CAP requirements."
    }
  ],
