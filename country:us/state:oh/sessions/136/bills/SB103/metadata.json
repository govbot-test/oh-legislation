  "abstracts": [
    {
      "note": "long title",
      "abstract": "To amend sections 4909.05, 4909.06, 4909.07, 4909.08, 4909.15, 4909.155, 4909.156, 4909.18, 4909.191, 4909.42, 4928.18, and 4929.041 and to enact sections 4903.30, 4929.052, 4929.053, 4929.054, 4929.055, 4929.056, 4929.057, 4929.058, 4929.059, and 4929.0510 of the Revised Code to allow for alternative rate plans for natural gas companies to serve large load customers and to make changes to the process of valuating natural gas company property."
    }
  ],
