  "abstracts": [
    {
      "note": "long title",
      "abstract": "To amend section 1345.81 and to enact sections 3937.51, 3937.52, 3937.53, and 3937.54 of the Revised Code to require certain disclosures, allow consumer choice concerning the use of aftermarket motor vehicle parts, to require the offering of coverage for original equipment manufacturer parts, and to name this act the Auto Insurance Transparency Act."
    }
  ],
  "other_titles": [
