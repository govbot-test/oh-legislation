  "abstracts": [
    {
      "note": "long title",
      "abstract": "To amend section 955.222 and to enact section 955.13 of the Revised Code to require a 10-day quarantine period for a dog following an attack and to require a court, under certain circumstances, to hold a hearing to determine the dog's disposition."
    }
  ],
