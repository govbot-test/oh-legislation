  "abstracts": [
    {
      "note": "long title",
      "abstract": "To amend section 4517.02 of the Revised Code to increase the number of vehicles, from five to fifteen, that a person may sell without obtaining a motor vehicle dealer license if the vehicles are over 12 years old."
    }
  ],
