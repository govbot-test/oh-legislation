  "abstracts": [
    {
      "note": "long title",
      "abstract": "To enact sections 3902.65 and 5164.081 of the Revised Code to require insurance and Medicaid coverage of the diagnosis and treatment of menopause, perimenopause, and menopausal and perimenopausal symptoms and to name this act the Ohio Menopause, Perimenopause, and Hormone Therapy Coverage Act."
    }
  ],
