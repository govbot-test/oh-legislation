  "abstracts": [
    {
      "note": "long title",
      "abstract": "To amend sections 323.152, 323.155, and 4503.06 and to enact section 319.305 of the Revised Code to authorize counties to temporarily exempt a portion of property's increased value from taxation following a reappraisal and to name this act the Calculated Adjustments for Property Surges (CAPS) Act."
    }
  ],
