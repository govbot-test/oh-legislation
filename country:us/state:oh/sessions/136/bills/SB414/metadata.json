  "abstracts": [
    {
      "note": "long title",
      "abstract": "To amend sections 3304.23, 4507.06, 4507.13, 4507.51, and 4507.52 and to enact sections 313.133, 3701.1311, 3705.081, 3902.65, and 5164.11 of the Revised Code regarding sudden unexpected death in epilepsy and to allow a person with epilepsy to enroll in the Disability Database and have an epilepsy designation on the person's driver's license or state ID."
    }
  ],
