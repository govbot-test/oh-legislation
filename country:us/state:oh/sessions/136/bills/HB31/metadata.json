{
  "legislative_session": "136",
  "identifier": "HB 31",
  "title": "Require electronic recordings of all parole board hearings",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Crime and Punishment",
    "Crimes, Corrections, and Law Enforcement",
