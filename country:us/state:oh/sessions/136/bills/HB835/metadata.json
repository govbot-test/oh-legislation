  "abstracts": [
    {
      "note": "long title",
      "abstract": "To amend sections 3705.16, 3795.03, and 3795.04 and to enact sections 313.124, 3793.01, 3793.02, 3793.03, 3793.04, 3793.05, 3793.06, 3793.07, 3793.08, 3793.09, 3793.10, 3793.11, 3793.12, 3793.13, 3793.14, 3793.15, 3793.16, 3793.17, 3793.18, 3793.19, 3793.20, 3793.21, and 4729.97 of the Revised Code to authorize an individual with a terminal condition and the ability to make and communicate health care decisions to request a prescription for an aid-in-dying medication and to name this act the Ohio Medical Aid in Dying (MAID) Act."
    }
  ],
  "other_titles": [
