  "abstracts": [
    {
      "note": "long title",
      "abstract": "To amend sections 2903.13 and 2929.13 of the Revised Code to increase the penalties for assault if the victim is acting as a sports official or the assault is committed in retaliation for the victim's actions as a sports official."
    }
  ],
