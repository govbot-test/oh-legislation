  "abstracts": [
    {
      "note": "long title",
      "abstract": "To amend sections 2152.17, 2901.13, and 2929.14 and to enact sections 2921.322 and 2941.1427 of the Revised Code to enact Katelyn's Law to create  an offense and specification related to moving or removing human remains and to provide that the offense has no statute of limitations."
    }
  ],
  "other_titles": [
    {
      "note": "long title",
      "title": "To amend sections 2152.17, 2901.13, and 2929.14 and to enact sections 2921.322 and 2941.1427 of the Revised Code to enact Katelyn's Law to create  an offense and specification related to moving or removing human remains and to provide that the offense has no statute of limitations."
    },
    {
      "note": "long title",
      "title": "To amend sections 2152.17, 2901.13, 2927.01, and 2929.14 and to enact sections 2921.322 and 2941.1427 of the Revised Code to enact Katelyn's Law to create  an offense and specification related to moving or removing human remains, to provide that the offense has no statute of limitations, and to modify the offense of abuse of a corpse."
    },
    {
      "note": "long title",
      "title": "To amend sections 2152.17, 2901.13, 2927.01, and 2929.14 and to enact sections 2921.322 and 2941.1427 of the Revised Code to enact Katelyn's Law to create an offense and specification related to moving or removing human remains, to provide that the offense has no statute of limitations, and to modify the offense of abuse of a corpse."
    }
  ],
