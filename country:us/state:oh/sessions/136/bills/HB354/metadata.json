  "abstracts": [
    {
      "note": "long title",
      "abstract": "To amend sections 2923.13 and 2923.14 of the Revised Code to enact the Keeping Our Survivors Safe Act to prohibit a person who has been convicted of first degree misdemeanor domestic violence from possessing a firearm or dangerous ordnance."
    }
  ],
