{
  "legislative_session": "136",
  "identifier": "SB 419",
  "title": "Revise temporary instruction permit eligibility, requirements",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Drivers' Licenses",
    "Public Safety",
    "Transportation"
  ],
  "abstracts": [
    {
      "note": "long title",
      "abstract": "To amend sections 4507.05 and 4507.071 of the Revised Code to lower the age at which a juvenile may obtain a temporary instruction permit from 15\u00bd to 15 and to expand the time a juvenile must hold a temporary instruction permit before eligibility for a probationary license from six months to one year."
    }
  ],
