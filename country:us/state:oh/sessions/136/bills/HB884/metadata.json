  "abstracts": [
    {
      "note": "long title",
      "abstract": "To amend sections 3317.011, 3317.012, 3317.018, 3317.0110, and 3317.022 and to enact section 3317.41 of the Revised Code and to amend Sections 265.10, as subsequently amended, 265.150, 265.190, and 265.450 of H.B. 96 of the 136th General Assembly regarding base cost calculation and use in the public school financing system, to express the General Assembly's intent to secure a thorough and efficient system of common schools, and to make an appropriation."
    }
  ],
