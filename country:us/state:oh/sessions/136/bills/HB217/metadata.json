{
  "legislative_session": "136",
  "identifier": "HB 217",
  "title": "Enact the Finding and Identifying with NamUs Data (FIND) Act",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Crimes, Corrections, and Law Enforcement",
    "Law Enforcement",
    "Public Records",
    "State and Local Government"
  ],
  "abstracts": [
    {
      "note": "long title",
      "abstract": "To amend sections 2901.30, 2901.41, and 2901.42 of the Revised Code to enact the Finding and Identifying with NamUs Data (FIND) Act to require law enforcement agencies to enter information relating to a report of a missing person in the national missing and unidentified persons system (NamUs)."
    }
  ],
  "other_titles": [
    {
      "note": "long title",
      "title": "To amend sections 2901.30, 2901.41, and 2901.42 of the Revised Code to enact the Finding and Identifying with NamUs Data (FIND) Act to require law enforcement agencies to enter information relating to a report of a missing person in the national missing and unidentified persons system (NamUs)."
    },
    {
      "note": "long title",
      "title": "To amend sections 2901.30, 2901.41, and 2901.42 and to enact section 109.5731 of the Revised Code to enact Andy Chapman's Act to require law enforcement agencies to enter information relating to a report of a missing person in the national missing and unidentified persons system (NamUs)."
    },
    {
      "note": "long title",
      "title": "To amend sections 2901.30, 2901.41, and 2901.42 and to enact section 109.5731 of the Revised Code to enact Andy Chapman's Act to require law enforcement agencies to enter information relating to a report of a missing person in the national missing and unidentified persons system (NamUs)."
    }
  ],
