  "abstracts": [
    {
      "note": "long title",
      "abstract": "To amend sections 3301.12, 5502.63, 5747.08, and 5747.98 and to enact sections 2923.1215, 2923.1216, 3901.97, 5502.621, and 5747.74 of the Revised Code to require secure storage of firearms, to authorize income tax credits, to name this act the Keep Every Home Safe Act, and to make an appropriation."
    }
  ],
