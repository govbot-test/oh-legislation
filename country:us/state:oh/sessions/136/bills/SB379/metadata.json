  "abstracts": [
    {
      "note": "long title",
      "abstract": "To amend sections 3313.60, 3314.03, 3326.11, and 3328.24 and to enact sections 109.44, 1349.07, 1349.071, 1349.072, 1349.073, 1349.074, 1349.075, 3301.0733, 3313.6034, and 5502.523 of the Revised Code to require the Attorney General to establish a statewide camera footage registry system, to impose various requirements on gaming platform providers and developers, to require public schools to provide grooming awareness and prevention instruction, and to name the act Hailey's Law."
    }
  ],
  "other_titles": [
