  "abstracts": [
    {
      "note": "long title",
      "abstract": "To amend section 2919.23 and to enact sections 2929.45, 4927.25, 4927.26, 4927.27, 4927.28, 4927.29, and 5502.55 of the Revised Code to modify the law governing interference with custody, to require wireless service providers to provide call location information to law enforcement in certain emergency situations, and to create an endangered missing child alert."
    }
  ],
  "other_titles": [
    {
      "note": "long title",
      "title": "To amend section 2919.23 and to enact sections 2929.45, 4927.25, 4927.26, 4927.27, 4927.28, 4927.29, and 5502.55 of the Revised Code to modify the law governing interference with custody, to require wireless service providers to provide call location information to law enforcement in certain emergency situations, and to create an endangered missing child alert."
    },
    {
      "note": "long title",
      "title": "To amend section 2919.23 and to enact sections 2929.45, 4927.25, 4927.26, 4927.27, 4927.28, 4927.29, and 5502.55 of the Revised Code to enact the Kelsey Smith Act to modify the law governing interference with custody, to require wireless service providers to provide call location information to law enforcement in certain emergency situations, and to create an endangered missing child alert."
    },
    {
      "note": "long title",
      "title": "To amend section 2919.23 and to enact sections 2929.45, 4927.25, 4927.26, 4927.27, 4927.28, 4927.29, and 5502.55 of the Revised Code to enact the Kelsey Smith Act to modify the law governing interference with custody, to require wireless service providers to provide call location information to law enforcement in certain emergency situations, and to create an endangered missing child alert."
    }
  ],
