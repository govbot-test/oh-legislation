  "abstracts": [
    {
      "note": "long title",
      "abstract": "To amend section 149.43 of the Revised Code to exempt from disclosure under Public Records Law, the name and address of a grand juror and the signature of a grand-jury foreperson, and to name this act the Grand Jury Privacy and Protection Act."
    }
  ],
