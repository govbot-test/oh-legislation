  "abstracts": [
    {
      "note": "long title",
      "abstract": "To amend sections 117.46, 121.01, 121.22, 149.011, 149.43, 187.01, 187.03, and 187.04 of the Revised Code to establish that records created by JobsOhio are public records under Ohio Public Records Law, to require JobsOhio to comply with the Open Meetings Law, and to require the Auditor of State to conduct a performance audit of JobsOhio."
    }
  ],
