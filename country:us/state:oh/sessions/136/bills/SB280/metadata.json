{
  "legislative_session": "136",
  "identifier": "SB 280",
  "title": "Allow registration of a humvee as a historical motor vehicle",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Military and Veterans",
    "Motor Vehicles",
