  ],
  "abstracts": [
    {
      "note": "long title",
      "abstract": "To amend sections 4501.01 and 4503.181 of the Revised Code to allow for the registration of a high-mobility multipurpose wheeled vehicle manufactured for military purposes, otherwise known as a humvee, as a historical motor vehicle."
    }
  ],
  "other_titles": [
    {
      "note": "long title",
      "title": "To amend sections 4501.01 and 4503.181 of the Revised Code to allow for the registration of a high-mobility multipurpose wheeled vehicle manufactured for military purposes, otherwise known as a humvee, as a historical motor vehicle."
    },
    {
      "note": "long title",
      "title": "To amend sections 4501.01, 4505.08, 4505.111, and 4513.02 and to enact sections 4503.184, 4505.073, and 4513.381 of the Revised Code to allow for the registration of a high mobility multipurpose wheeled vehicle manufactured for military purposes, commonly known as a humvee."
    },
    {
