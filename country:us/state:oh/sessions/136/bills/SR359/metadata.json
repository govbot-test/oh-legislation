  "abstracts": [
    {
      "note": "long title",
      "abstract": "To urge the Supreme Court of Ohio and the Ohio judicial system to encourage remote appearances of sexual assault nurse examiners in sexual assault trials so that sexual assault nurse examiners can spend less time in courtrooms and more time providing valuable services to victims of sexual assault."
    }
  ],
