{
  "legislative_session": "136",
  "identifier": "HB 413",
  "title": "Regards Ohio State, Local Government Expenditure Databases",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "State and Local Government"
  ],
  "abstracts": [
    {
      "note": "long title",
      "abstract": "To amend sections 113.70, 113.71, 113.72, 113.73, 113.74, 113.75, 113.76, and 5501.521; to enact new section 113.77 and sections 113.80, 113.81, 113.82, 113.83, and 113.84; and to repeal section 113.77 of the Revised Code to create the Ohio Local Government Expenditure Database and require political subdivision participation, to require the state retirement systems to participate in the Ohio State Government Expenditure Database, and to make an appropriation."
    }
  ],
