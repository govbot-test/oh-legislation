  ],
  "abstracts": [
    {
      "note": "long title",
      "abstract": "To amend sections 3301.50, 3301.53, 3301.54, 3301.56, 3313.48, 3313.64, 3313.646, 3313.842, 3313.98, 3313.981, 3314.03, 3314.08, 3317.011, 3317.0110, 3317.02, 3317.0213, 3317.03, 3321.01, 3321.05, 3323.02, 5753.021, and 5753.031 and to enact sections 3301.542, 3301.591, 3301.592, 3313.6415, and 3317.083 of the Revised Code to increase the rate of the sports gaming tax on certain operators, to require all-day kindergarten, to establish universal preschool programs, and to name this act the Preschool for All Act."
    }
  ],
  "other_titles": [
    {
