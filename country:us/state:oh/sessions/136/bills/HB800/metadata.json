  "legislative_session": "136",
  "identifier": "HB 800",
  "title": "Enact the Preschool for All Act",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Early Childhood Education",
    "Education",
