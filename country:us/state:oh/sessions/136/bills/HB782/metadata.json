  "abstracts": [
    {
      "note": "long title",
      "abstract": "To amend section 5747.01 and to enact section 5180.23 of the Revised Code to establish the At-Home Infant Care Program in the Department of Children and Youth, to exempt payments received under the program from the state income tax, to name this act the At-Home Infant Care Program Act, and to make an appropriation."
    }
  ],
