  "other_titles": [
    {
      "note": "long title",
      "title": "To amend sections 109.57, 109.60, 2953.32, and 5122.311 of the Revised Code and to amend Section 221.40 of H.B. 96 of the 136th General Assembly, as subsequently amended, to align and modernize fingerprinting and disposition reporting."
    },
    {
      "note": "long title",
      "title": "To amend sections 109.57, 109.573, 109.60, 2953.32, and 5122.311 of the Revised Code and to amend Section 221.40 of H.B. 96 of the 136th General Assembly, as subsequently amended, to align and modernize fingerprinting and disposition reporting, and to allow disclosure of information related to actions to determine paternity."
    },
