{
  "legislative_session": "136",
  "identifier": "HB 393",
  "title": "Require certain facilities assist inmates in obtaining ID cards",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Crimes, Corrections, and Law Enforcement",
