{
  "legislative_session": "136",
  "identifier": "HB 505",
  "title": "Restrict use of crowdfunding money for other purposes",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Crime and Punishment",
    "Crimes, Corrections, and Law Enforcement"
  ],
  "abstracts": [
    {
      "note": "long title",
      "abstract": "To enact sections 1349.07, 1349.071, 1349.072, 1349.073, 1349.074, 1349.075, 1349.076, and 1349.08 of the Revised Code to restrict the use of funds collected through crowdfunding for purposes other than those solicited."
    }
  ],
  "other_titles": [
    {
      "note": "long title",
      "title": "To enact sections 1349.07, 1349.071, 1349.072, 1349.073, 1349.074, 1349.075, 1349.076, and 1349.08 of the Revised Code to restrict the use of funds collected through crowdfunding for purposes other than those solicited."
    },
    {
      "note": "long title",
      "title": "To enact sections 1716.30, 1716.301, 1716.302, 1716.303, 1716.304, 1716.305, 1716.306, 1716.307, 1716.308, and 1716.309 of the Revised Code to prohibit the use of funds collected through crowdfunding for fraudulent or misleading purposes and to require crowdfunding platforms to register with the Attorney General."
    }
  ],
