  "abstracts": [
    {
      "note": "long title",
      "abstract": "To amend sections 4164.11, 4906.01, 4906.03, 4928.01, and 4928.041 and to enact sections 4164.20, 4928.76, 4928.761, 4928.762, 4928.763, 4928.764, 4928.765, 4928.766, 4928.767, 4928.768, and 4928.769 of the Revised Code to authorize electric distribution utilities to construct, own, and operate nuclear generating facilities in limited circumstances and to require the Ohio Nuclear Development Authority to appoint a State Nuclear Coordinator."
    }
