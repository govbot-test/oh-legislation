  "legislative_session": "136",
  "identifier": "HB 790",
  "title": "Designate the Honor and Remember flag; encourage flag display",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Special Designations"
  ],
  "abstracts": [
    {
      "note": "long title",
      "abstract": "To enact section 9.51 of the Revised Code to designate the Honor and Remember flag as the symbol of Ohio's concern and commitment to honoring and remembering the lives of all fallen service members and their families and to encourage that the flag be displayed at the Statehouse in Columbus on Memorial Day."
    }
  ],
  "other_titles": [
