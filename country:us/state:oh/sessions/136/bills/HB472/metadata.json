{
  "legislative_session": "136",
  "identifier": "HB 472",
  "title": "Waive ID, birth certificate fees for homeless individuals",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Health and Human Services",
    "Housing and Real Property",
