{
  "legislative_session": "136",
  "identifier": "HB 25",
  "title": "Establish the Foster-to-College Scholarship Program",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Education",
    "Finance and Appropriations",
    "Higher Education",
    "Primary and Secondary Education"
  ],
  "abstracts": [
    {
      "note": "long title",
      "abstract": "To enact sections 3301.96 and 3333.89 of the Revised Code to establish the Foster-to-College Scholarship Program, to require the Department of Education and Workforce to hire a full-time school foster care liaison, and to make an appropriation for the Foster-to-College Scholarship Program."
    }
  ],
  "other_titles": [
    {
      "note": "long title",
      "title": "To enact sections 3301.96 and 3333.89 of the Revised Code to establish the Foster-to-College Scholarship Program, to require the Department of Education and Workforce to hire a full-time school foster care liaison, and to make an appropriation for the Foster-to-College Scholarship Program."
    },
    {
      "note": "long title",
      "title": "To amend sections 3314.03 and 3326.11 and to enact sections 3301.96, 3313.475, and 5103.62 of the Revised Code to enact the Fostering School Success Act."
    },
    {
      "note": "long title",
      "title": "To amend sections 3314.03 and 3326.11 and to enact sections 3301.96, 3313.475, and 5103.62 of the Revised Code to enact the Fostering School Success Act."
    }
  ],
