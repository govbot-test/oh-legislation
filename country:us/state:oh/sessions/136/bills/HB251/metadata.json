  "legislative_session": "136",
  "identifier": "HB 251",
  "title": "Regards drone use by law enforcement; aviation facilities",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Air and Rail Transport",
    "Crimes, Corrections, and Law Enforcement",
