    },
    {
      "note": "long title",
      "title": "To amend sections 5104.01, 5104.30, 5104.32, 5104.34, 5104.38, and 5104.53 and to enact sections 5104.321 and 5104.45 of the Revised Code to revise the law governing the publicly funded child care program."
    },
