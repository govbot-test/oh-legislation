  "abstracts": [
    {
      "note": "long title",
      "abstract": "To amend sections 3.07, 3.17, 305.03, 503.241, and 3313.11 and to enact section 3.171 of the Revised Code to allow an elected official who is deployed on active military duty to retain the official's position and to attend meetings virtually."
    }
  ],
