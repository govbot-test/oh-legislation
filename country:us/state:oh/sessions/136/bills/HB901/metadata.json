  "abstracts": [
    {
      "note": "long title",
      "abstract": "To amend sections 2923.11, 5739.01, 5739.02, 5739.03, 5739.17, 5747.08, and 5747.98 and to enact sections 2923.26, 2923.27, 3701.982, and 5747.74 of the Revised Code to enact Amya's Law for Child Access Prevention to provide for the safe storage of firearms, to authorize a nonrefundable income tax credit for the purchase of secure storage and safety devices, and to exempt such devices from sales and use tax."
    }
  ],
  "other_titles": [
