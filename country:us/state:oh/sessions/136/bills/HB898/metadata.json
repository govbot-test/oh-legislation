  "abstracts": [
    {
      "note": "long title",
      "abstract": "To amend sections 2151.011, 2151.28, 2151.35, 2151.412, 2151.414, 2151.415, 2151.416, 2151.417, and 3107.062 and to enact sections 2151.47, 2151.471, 3109.121, and 3109.122 of the Revised Code to enact the Putative Fathers Matter Act to require notice to putative fathers regarding child welfare hearings and companionship or visitation proceedings and to require notice to grandparents regarding child welfare hearings."
    }
  ],
