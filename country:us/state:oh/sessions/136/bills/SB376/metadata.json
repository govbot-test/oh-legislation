  "abstracts": [
    {
      "note": "long title",
      "abstract": "To amend sections 5747.50, 5747.502, 5747.51, and 5747.53 and to enact sections 9.662, 743.80, 5747.504, and 5747.505 of the Revised Code to create a process for withholding local government funds and state water and sewer assistance from municipal corporations that engage in certain water and sewer practices with respect to extraterritorial service."
    }
  ],
