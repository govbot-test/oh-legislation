    "Sentencing"
  ],
  "abstracts": [
    {
      "note": "long title",
      "abstract": "To amend sections 2929.12, 2929.15, and 2929.25 of the Revised Code to prohibit a sentencing court from imposing, as a condition of community control, a requirement that the offender admit guilt if the offender was found guilty after entering an Alford plea and to name this act the Alford Plea Fairness Act."
    }
  ],
  "other_titles": [
    {
