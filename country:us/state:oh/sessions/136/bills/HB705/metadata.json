  "legislative_session": "136",
  "identifier": "HB 705",
  "title": "Enact the Alford Plea Fairness Act",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Courts",
    "Courts and Civil Law",
    "Crime and Punishment",
