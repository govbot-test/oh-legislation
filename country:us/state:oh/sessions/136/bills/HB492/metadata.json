    },
    {
      "note": "long title",
      "title": "To amend section 4513.36 of the Revised Code to expand the prohibition against interfering with arrest to all motor vehicle-related laws and require drivers and passengers to disclose their name, address, and date of birth to a peace officer on request."
    },
