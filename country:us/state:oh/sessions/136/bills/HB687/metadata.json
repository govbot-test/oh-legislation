  "abstracts": [
    {
      "note": "long title",
      "abstract": "To amend section 3701.851 and to enact section 3701.852 of the Revised Code regarding staffing requirements in athletic facilities with staff trained in automated external defibrillation and cardiopulmonary resuscitation."
    }
  ],
  "other_titles": [
    {
      "note": "long title",
      "title": "To amend section 3701.851 and to enact section 3701.852 of the Revised Code regarding staffing requirements in athletic facilities with staff trained in automated external defibrillation and cardiopulmonary resuscitation."
    },
    {
      "note": "long title",
      "title": "To amend sections 755.13, 3313.717, 3314.16, and 3701.851 and to enact section 3701.852 of the Revised Code regarding staffing requirements in athletic facilities with staff trained in automated external defibrillation and cardiopulmonary resuscitation, placement of automated external defibrillators in school-related locations, and emergency action plans adopted by sports and recreation locations and schools."
    }
  ],
