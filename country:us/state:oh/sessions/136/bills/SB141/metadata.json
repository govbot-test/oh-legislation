  "abstracts": [
    {
      "note": "long title",
      "abstract": "To amend section 5705.19 and to enact section 307.852 of the Revised Code to authorize counties and other political subdivisions to place on the ballot tax levies supporting pre-kindergarten programs and to establish conditions on a county's use of moneys derived from the levied tax."
    }
  ],
