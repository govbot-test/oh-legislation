  "abstracts": [
    {
      "note": "long title",
      "abstract": "To amend sections 151.01, 151.08, 164.03, 164.08, 3318.042, 3318.49, 3343.05, 5751.02, and 5751.20 and to enact sections 3318.33 and 3343.11 of the Revised Code and to amend Sections 357.09, 357.15, 357.16, 357.24, 357.28, 357.34, 357.36, 371.10, 371.20, 373.10, 373.15, 387.10, and 387.13 of H.B. 730 of the 136th General Assembly and Section 200.30 of H.B. 2 of the 135th General Assembly as subsequently amended to make capital appropriations for the biennium ending June 30, 2028, and to declare an emergency."
    }
  ],
