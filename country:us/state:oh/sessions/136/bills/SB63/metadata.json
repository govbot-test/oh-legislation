{
  "legislative_session": "136",
  "identifier": "SB 63",
  "title": "Prohibit use of ranked choice voting; withhold funding for use",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Elections",
    "Local Government",
    "State and Local Government"
  ],
  "abstracts": [
    {
      "note": "long title",
      "abstract": "To amend sections 3501.01 and 5747.502 and to enact sections 3505.011, 3513.141, 5747.504, and 5747.505 of the Revised Code to generally prohibit the use of ranked choice voting and to withhold Local Government Fund distributions from a municipality or chartered county that uses ranked choice voting."
    }
  ],
  "other_titles": [
    {
      "note": "long title",
      "title": "To amend sections 3501.01 and 5747.502 and to enact sections 3505.011, 3513.141, 5747.504, and 5747.505 of the Revised Code to generally prohibit the use of ranked choice voting and to withhold Local Government Fund distributions from a municipality or chartered county that uses ranked choice voting."
    },
    {
      "note": "long title",
      "title": "To amend sections 3501.01 and 5747.502 and to enact sections 3505.011, 3513.141, 5747.504, and 5747.505 of the Revised Code to generally prohibit the use of ranked choice voting and to withhold Local Government Fund distributions from a municipality or chartered county that uses ranked choice voting."
    },
    {
      "note": "long title",
      "title": "To amend sections 3501.01 and 5747.502 and to enact sections 3505.011, 3513.141, 5747.504, and 5747.505 of the Revised Code to generally prohibit the use of ranked choice voting and to withhold Local Government Fund distributions from a municipality or chartered county that uses ranked choice voting."
    },
    {
      "note": "long title",
      "title": "To amend sections 3501.01, 3513.05, 3513.262, 3513.263, and 5747.502 and to enact sections 3505.011, 3513.141, 5747.504, and 5747.505 of the Revised Code to generally prohibit the use of ranked choice voting, to withhold Local Government Fund distributions from a municipality or chartered county that uses ranked choice voting, and to make changes to election petition records."
    },
    {
      "note": "long title",
