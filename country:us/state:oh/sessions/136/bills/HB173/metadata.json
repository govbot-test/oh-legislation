{
  "legislative_session": "136",
  "identifier": "HB 173",
  "title": "Regards entities providing behind-the-meter utility services",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Utilities"
  ],
  "abstracts": [
    {
      "note": "long title",
      "abstract": "To amend section 4905.02 and to enact sections 4933.51, 4933.52, 4933.54, 4933.56, 4933.57, 4933.59, 4933.60, and 4933.63 of the Revised Code to exempt from regulation as a public utility certain persons or entities providing behind-the-meter utility services and to allow the Public Utilities Commission to register providers of such services."
    }
  ],
  "other_titles": [
