  "abstracts": [
    {
      "note": "long title",
      "abstract": "To amend section 2921.04 and to enact section 2921.06 of the Revised Code to create the offense of jury tampering and to include a public servant in the offense of intimidation of an attorney, victim, witness, or public servant in a criminal case."
    }
  ],
