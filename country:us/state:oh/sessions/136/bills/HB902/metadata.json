{
  "legislative_session": "136",
  "identifier": "HB 902",
  "title": "Enact the Fostering Sibling Success Act",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Child Welfare",
    "Foster Care",
    "Juvenile and Family Law"
  ],
  "abstracts": [
    {
      "note": "long title",
      "abstract": "To amend sections 2151.011, 2151.411, 2151.412, 2151.416, 2151.417, 2151.4122, 2151.424, and 5103.161; to enact new sections 2151.4115, 2151.4116, 2151.4117, 2151.4118, 2151.4119, and 2151.4120 and section 2151.317; and to repeal sections 2151.4115, 2151.4116, 2151.4117, 2151.4118, 2151.4119, 2151.4120, and 2151.4121 of the Revised Code to enact the \"Fostering Sibling Success Act\" regarding the rights of sibling youths in foster care and to provide for continuation of a child's placement and limit kinship preference in foster care."
    }
  ],
  "other_titles": [
    {
      "note": "long title",
      "title": "To amend sections 2151.011, 2151.411, 2151.412, 2151.416, 2151.417, 2151.4122, 2151.424, and 5103.161; to enact new sections 2151.4115, 2151.4116, 2151.4117, 2151.4118, 2151.4119, and 2151.4120 and section 2151.317; and to repeal sections 2151.4115, 2151.4116, 2151.4117, 2151.4118, 2151.4119, 2151.4120, and 2151.4121 of the Revised Code to enact the \"Fostering Sibling Success Act\" regarding the rights of sibling youths in foster care and to provide for continuation of a child's placement and limit kinship preference in foster care."
    }
  ],
