  "abstracts": [
    {
      "note": "long title",
      "abstract": "To amend sections 2929.01, 2929.14, 2929.144, 2929.19, 2953.08, 2967.193, and 2967.194 of the Revised Code to require every sentence of imprisonment for a felony offense be for an indefinite period consisting of a minimum and maximum term and to change the maximum term that applies to those offenses."
    }
  ],
  "other_titles": [
