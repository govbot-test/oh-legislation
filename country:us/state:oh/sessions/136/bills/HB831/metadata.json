  "abstracts": [
    {
      "note": "long title",
      "abstract": "To amend section 3902.50 and to enact sections 5.22108, 3902.65, and 5164.094 of the Revised Code to require health plan issuers and the Medicaid program to cover treatments and services related to Pediatric Autoimmune Neuropsychiatric Disorders Associated with Streptococcal Infections and Pediatric Acute-onset Neuropsychiatric Syndrome."
    }
  ],
