  "abstracts": [
    {
      "note": "long title",
      "abstract": "To amend sections 3314.03, 3326.11, and 3328.24 and to enact section 3313.475 of the Revised Code and to amend Section 221.20 of H.B. 96 of the 136th General Assembly to require public and chartered nonpublic schools to purchase and install an exterior secure master key box on each school building."
    }
  ],
  "other_titles": [
