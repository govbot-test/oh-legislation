{
  "legislative_session": "136",
  "identifier": "HB 807",
  "title": "Prohibit selling sensitive personal data for profit",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Commerce",
    "Social Media",
