  "abstracts": [
    {
      "note": "long title",
      "abstract": "To amend sections 1347.01, 1347.10, and 1347.99 and to enact section 1347.072 of the Revised Code to prohibit various government and private entities from selling sensitive personal data to a data broker or private entity with the intent of generating profit, unless used for a permitted purpose."
    }
  ],
