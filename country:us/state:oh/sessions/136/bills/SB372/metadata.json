  "abstracts": [
    {
      "note": "long title",
      "abstract": "To enact section 126.17 of the Revised Code to require the Director of Budget and Management to establish and administer a centralized reporting system for financial status reports regarding public money provided through a grant or loan program, or through an economic development program, a workforce development program, or a public assistance program."
    }
  ],
