{
  "legislative_session": "136",
  "identifier": "HB 855",
  "title": "Enact the Ohio Safe Homes Act",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Housing and Real Property",
    "Landlords and Tenants",
    "Taxation"
  ],
  "abstracts": [
    {
      "note": "long title",
      "abstract": "To amend sections 3767.01, 3767.05, 4301.74, 5321.02, and 5747.98 and to enact sections 5321.172 and 5747.35 of the Revised Code to allow a tenant to terminate a rental agreement if the tenant is a victim of a specified crime, to authorize an income tax credit for landlords who rented to such tenants, and to name this act the Ohio Safe Homes Act."
    }
  ],
  "other_titles": [
    {
      "note": "long title",
