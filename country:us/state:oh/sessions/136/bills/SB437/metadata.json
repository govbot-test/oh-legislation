  "abstracts": [
    {
      "note": "long title",
      "abstract": "To amend section 9.63 of the Revised Code to withhold all state funding from municipal corporations that do not cooperate with federal homeland security activities and remove the Director of Public Safety's role in determining what constitutes noncooperation."
    }
  ],
