{
  "legislative_session": "136",
  "identifier": "HB 58",
  "title": "Create recovery housing residences certificate of need program",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Health and Human Services",
    "Substance Abuse and Addiction"
  ],
  "abstracts": [
    {
      "note": "long title",
      "abstract": "To amend section 5119.393 and to enact sections 5119.398, 5119.399, 5119.3910, 5119.3911, 5119.3912, 5119.3913, 5119.3914, and 5119.3915 of the Revised Code to create a certificate of need program for recovery housing residences."
    }
  ],
  "other_titles": [
    {
      "note": "long title",
      "title": "To amend section 5119.393 and to enact sections 5119.398, 5119.399, 5119.3910, 5119.3911, 5119.3912, 5119.3913, 5119.3914, and 5119.3915 of the Revised Code to create a certificate of need program for recovery housing residences."
    },
    {
      "note": "long title",
      "title": "To amend sections 340.034, 2925.01, 5119.01, 5119.36, 5119.365, 5119.39, 5119.392, 5119.393, 5119.394, 5119.396, 5119.94, and 5119.99; to enact new section 5119.391 and sections 5119.02, 5119.369, 5119.398, and 5119.399; and to repeal sections 5119.391, 5119.395, and 5119.397 of the Revised Code to require state certification of recovery housing residences, to establish additional duties regarding services offered by community addiction services providers, and to create the Ohio Recovery Housing Task Force."
    },
    {
      "note": "long title",
      "title": "To amend sections 340.034, 2925.01, 5119.01, 5119.36, 5119.365, 5119.39, 5119.392, 5119.393, 5119.394, 5119.396, 5119.94, and 5119.99; to enact new section 5119.391 and sections 5119.02, 5119.369, 5119.398, and 5119.399; and to repeal sections 5119.391, 5119.395, and 5119.397 of the Revised Code to require state certification of recovery housing residences, to establish additional duties regarding services offered by community addiction services providers, and to create the Ohio Recovery Housing Task Force."
    }
  ],
