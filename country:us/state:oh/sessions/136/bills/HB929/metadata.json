  "abstracts": [
    {
      "note": "long title",
      "abstract": "To amend sections 4501.01, 4503.10, 4503.103, 4503.107, 4506.14, 4507.09, and 4507.501 of the Revised Code to require all limited term licenses and identification cards to have a maximum one-year expiration and prohibit multi-year or permanent vehicle-related registrations for temporary residents."
    }
  ],
