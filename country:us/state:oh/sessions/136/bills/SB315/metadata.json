{
  "legislative_session": "136",
  "identifier": "SB 315",
  "title": "Enact the Enhanced Cybersecurity for SNAP Act",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Health and Human Services",
    "Public Assistance"
  ],
  "abstracts": [
    {
      "note": "long title",
      "abstract": "To amend sections 5101.54 and 5101.542 of the Revised Code to require Ohio's SNAP program to begin using chip-enabled EBT cards, to name this act the Enhanced Cybersecurity for SNAP Act, and to make an appropriation."
    }
  ],
  "other_titles": [
    {
